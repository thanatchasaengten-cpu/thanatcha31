<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="เว็บไซต์แสดงผลงานและทักษะของ  ธนัชชา เซี่ยงเท่น ">
    <title>ความภาคภูมิใจของ ธน้ชชา เซี่ยงเท่น</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- ส่วนหัวของเว็บ -->
    <header>
        <h1>สวัสดี! ดิฉันคือธนัชชา เซี่ยงเท่น </h1>
        <p>นี่คือผลงานและความภาคภูมิใจของฉัน</p>
    </header>

    <!-- ส่วนเกี่ยวกับตัวเอง -->
    <section id="about">
        <h2>เกี่ยวกับฉัน</h2>
        <p>ฉันเป็นคนที่มีความสามารถในการทำอาหารเเละมันคือสิ่งที่ฉันชอบมาตั้งเเต่เด็กเเต่ก็ผ่านความรับบากในการทำมามากพอสมควร</p>
    </section>

    <!-- ส่วนแสดงผลงาน -->
    <section id="projects">
        <h2> ฉันสามารถทำอาหารให้คนที่บ้านกินได้อย่างอร่อย </h2>

        <div class="project">
            <h3>เว็บไซต์ Portfolio</h3>
            <p>เว็บไซต์นี้เป็นหนึ่งในผลงานที่ฉันสร้างขึ้นเพื่อแสดงความสามารถของดิฉัน</p>
        </div>

        <div class="project">
            <h3>การทำอาหารขาย</h3>
            <p>ทำอาหารเพื่อสุขภาพขาย</p>
        </div>
    </section>

    <!-- ส่วนแสดงทักษะ -->
    <section id="skills">
        <h2>ทักษะของฉัน </h2>
        <ul>
            <li>HTML, CSS, JavaScript</li>
            <li>Python, Django</li>
            <li>Git และ GitHub</li>
            <li>การออกแบบ UI/UX</li>
        </ul>
    </section>

    <!-- ส่วนติดต่อและลิขสิทธิ์ -->
    <footer>
        <p>ติดต่อดิฉันได้:
            <a href="mailto:ธนัชชา เซี่ยงเท่น@example.com">ธนัชชา เซี่ยงเท่น@example.com</a>
        </p>
        <p>&copy; <span id="year"></span> ธนัชชา เซี่ยงเท่น . All rights reserved. </p>
    </footer>

    <!-- ลิงก์ไปยัง JavaScript -->
    <script src="script.js"></script>

</body>
</html>
